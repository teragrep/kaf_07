}

#
# Install kaf_06
#

bundle agent install_kaf_06(config) {
  methods:
      "any" usebundle => install_rpm("kaf_06"),
        classes => if_repaired("kaf_06_repaired");
  vars:
      # iterators
      "controllers" slist => getindices("config[kafka][controllers]");
      "brokers" slist => getindices("config[kafka][brokers]");

      # Common
      "bootstrap[$(controllers)]" string => "$(config[kafka][controllers][$(controllers)][hostname]):$(config[kafka][ports][controller])";
      "bootstrapstring" string => join(",", bootstrap);
      "voters[$(controllers)]" string => "$(config[kafka][controllers][$(controllers)][id])@$(config[kafka][controllers][$(controllers)][hostname]):$(config[kafka][ports][controller])";
      "votersstring" string => join(",", voters);

      # Handle controller-specific data
      "controllerid" string => "$(config[kafka][controllers][$(controllers)][id])",
        if => strcmp("$(config[kafka][controllers][$(controllers)][hostname])", "$(sys.fqhost)");
      "controllerdata" data => mergedata(@(config), '{"injected": { "id": "$(controllerid)", "port": "$(config[kafka][ports][controller])", "isbroker": false, "voters": "$(votersstring)", "bootstrap": "$(bootstrapstring)", "role": "controller", "jmxpassword": "$(config[kafka][jmx][controller][password])" } }'),
        if => isvariable("controllerid");

      # Handle broker-specific data
      "brokerid" string => "$(config[kafka][brokers][$(brokers)][id])",
        if => strcmp("$(config[kafka][brokers][$(brokers)][hostname])", "$(sys.fqhost)");
      "brokerdata" data => mergedata(@(config), '{"injected": { "id": "$(brokerid)", "port": "$(config[kafka][ports][broker])", "isbroker": true, "voters": "$(votersstring)", "bootstrap": "$(bootstrapstring)", "role": "broker", "jmxpassword": "$(config[kafka][jmx][broker][password])" } }'),
        if => isvariable("brokerid");
  files:
      # Common configuration for both roles
      "$(config[kaf_06][dirs][logs])/."
        create => "true",
        if => or(
                  "kaf_06_installed",
                  "kaf_06_install_ok"
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kaf_06][dirs][etc])/."
        create => "true",
        if => or(
                  "kaf_06_installed",
                  "kaf_06_install_ok"
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kaf_06][dirs][workdir])/."
        create => "true",
        if => or(
                  "kaf_06_installed",
                  "kaf_06_install_ok"
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kaf_06][dirs][etc])/kafka.jaas.conf"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/kafka.jaas.conf.mustache",
        template_method => "mustache",
        template_data => @(config),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   )
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kafka][config][log_dirs])/."
        create => "true",
        if => and(
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   )
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      # Broker related files
      "$(config[kaf_06][dirs][etc])/kafka-broker.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/kafka.properties.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_broker_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kafka][config][log_dirs])/broker/."
        create => "true",
        if => and(
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kafka][config][log_dirs])/broker/meta.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/meta.properties.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kafka][config][log_dirs])/broker/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("brokerdata"),
                   not(fileexists("$(config[kafka][config][log_dirs])/broker/meta.properties"))
        ),
        classes => if_repaired("kaf_06_controller_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "/usr/lib/systemd/system/kaf_06-broker.service"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/kaf_06-broker.service.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_controller_service_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_06][dirs][etc])/log4j-broker.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/log4j.properties.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   not(fileexists("$(config[kaf_06][dirs][etc])/log4j-broker.properties")),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_06][dirs][logs])/broker/."
        create => "true",
        if => and(
                   isdir("$(config[kaf_06][dirs][logs])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      # Broker JMX related files
      "$(config[kaf_06][dirs][etc])/jmxremote-broker.access"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/jmxremote.access.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   strcmp("$(config[kafka][jmx][broker][enabled])", "true"),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "600");
      "$(config[kaf_06][dirs][etc])/jmxremote-broker.password"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/jmxremote.password.mustache",
        template_method => "mustache",
        template_data => @(brokerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   strcmp("$(config[kafka][jmx][broker][enabled])", "true"),
                   isvariable("brokerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "600");
      # Controller related files
      "$(config[kaf_06][dirs][etc])/kafka-controller.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/kafka.properties.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_controller_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kafka][config][log_dirs])/controller/."
        create => "true",
        if => and(
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kafka][config][log_dirs])/controller/meta.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/meta.properties.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kafka][config][log_dirs])/controller/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("controllerdata"),
                   not(fileexists("$(config[kafka][config][log_dirs])/controller/meta.properties"))
        ),
        classes => if_repaired("kaf_06_controller_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "/usr/lib/systemd/system/kaf_06-controller.service"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/kaf_06-controller.service.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_controller_service_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_06][dirs][etc])/log4j-controller.properties"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/log4j.properties.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   not(fileexists("$(config[kaf_06][dirs][etc])/log4j-controller.properties")),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_06][dirs][logs])/controller/."
        create => "true",
        if => and(
                   isdir("$(config[kaf_06][dirs][logs])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      # Controller JMX related files
      "$(config[kaf_06][dirs][etc])/jmxremote-controller.access"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/jmxremote.access.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   strcmp("$(config[kafka][jmx][controller][enabled])", "true"),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "600");
      "$(config[kaf_06][dirs][etc])/jmxremote-controller.password"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_06/jmxremote.password.mustache",
        template_method => "mustache",
        template_data => @(controllerdata),
        if => and(
                   isdir("$(config[kaf_06][dirs][etc])/"),
                   or(
                       "kaf_06_installed",
                       "kaf_06_install_ok"
                   ),
                   strcmp("$(config[kafka][jmx][controller][enabled])", "true"),
                   isvariable("controllerdata")
        ),
        classes => if_repaired("kaf_06_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "600");
  reports:
      "[ERROR] kaf_06 was not properly installed"
        if => and(
                  not("kaf_06_installed"),
                  not("kaf_06_install_ok")
        );
      "[INFO] kaf_06 generic files changed, please restart service(s)"
        if => "kaf_06_repaired";
      "[INFO] kaf_06 broker files changed, please restart broker service"
        if => or(
                  "kaf_06_broker_repaired",
                  "kaf_06_broker_service_repaired"
        );
      "[INFO] kaf_06 controller files changed, please restart controller service"
        if => or(
                  "kaf_06_controller_repaired",
                  "kaf_06_controller_service_repaired"
        );
      "[INFO] kaf_06 systemd service(s) changed, please run 'systemctl daemon-reload' to get new settings"
        if => or(
                  "kaf_06_broker_service_repaired",
                  "kaf_06_controller_service_repaired"
        );
      "[WARNING] Couldn't determine whether this host was a broker or a controller"
        if => and(
                   not(isvariable("brokerdata")),
                   not(isvariable("controllerdata"))
        );
}
