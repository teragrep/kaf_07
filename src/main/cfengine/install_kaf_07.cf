body file control
{
        namespace => "install_kaf_07";
}

#
# Main handlers
#

bundle agent install_kaf_07 {
  classes:
      "kaf_04_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/rpm/kaf_04.rpm");
      "kaf_04_authorize_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/config/kaf_04/authorize.json");
      "kaf_05_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/rpm/kaf_05.rpm");
      "kaf_05_credentials_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/config/kaf_05/credentials.json");
      "kaf_06_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/rpm/kaf_06.rpm");
      "config_exists" expression => "any",
        if => fileexists("$(this.promise_dirname)/config/config.json");
  methods:
      "any" usebundle => install_handler,
        if => and(
                   "kaf_04_exists",
                   "kaf_04_authorize_exists",
                   "kaf_05_exists",
                   "kaf_05_credentials_exists",
                   "kaf_06_exists",
                   "config_exists"
        );
  reports:
      "[ERROR] Missing $(this.promise_dirname)/rpm/kaf_04.rpm" if => not("kaf_04_exists");
      "[ERROR] Missing $(this.promise_dirname)/config/kaf_04/authorize.json" if => not("kaf_04_authorize_exists");
      "[ERROR] Missing $(this.promise_dirname)/rpm/kaf_05.rpm" if => not("kaf_05_exists");
      "[ERROR] Missing $(this.promise_dirname)/config/kaf_05/credentials.json" if => not("kaf_05_credentials_exists");
      "[ERROR] Missing $(this.promise_dirname)/rpm/kaf_06.rpm" if => not("kaf_06_exists");
      "[ERROR] Missing $(this.promise_dirname)/config/config.json" if => not("config_exists");
}

bundle agent install_handler {
  vars:
      "config_plain" data => readdata("$(this.promise_dirname)/config/config.json", "JSON"),
        if => fileexists("$(this.promise_dirname)/config/config.json");
      "config" data => mergedata(@(config_plain), '{"fqdn": "$(sys.fqhost)"}');
  methods:
      "kaf_04" usebundle => install_kaf_04(@(config));
      "kaf_05" usebundle => install_kaf_05(@(config));
      "kaf_06" usebundle => install_kaf_06(@(config));
  reports:
      "[ERROR] Failed to parse config"
        if => or(
                  not(isvariable("config_plain")),
                  not(isvariable("config"))
        );

}

#
# Generic RPM installer bundle
#

bundle agent install_rpm(rpm) {
  vars:
      "$(rpm)_version" string => execresult("/bin/rpm -qp $(this.promise_dirname)/rpm/$(rpm).rpm --nosignature", "noshell"),
        handle => "$(rpm)_version_check_done",
        if => fileexists("$(this.promise_dirname)/rpm/$(rpm).rpm");
  classes:
      "$(rpm)_installed" expression => returnszero("/bin/rpm --quiet -q $($(rpm)_version)", "noshell"),
        handle => "$(rpm)_installed_check_done",
        depends_on => { "$(rpm)_version_check_done" },
        scope => "namespace";
  commands:
      "/usr/bin/yum -y install $(this.promise_dirname)/rpm/$(rpm).rpm"
        if => not("$(rpm)_installed"),
        depends_on => { "$(rpm)_installed_check_done" },
        classes => if_ok("$(rpm)_install_ok");
  reports:
      "[ERROR] Can't install rpm $(this.promise_dirname)/rpm/$(rpm).rpm"
        if => and(
                   not("$(rpm)_installed"),
                   not("$(rpm)_install_ok")
        );
}

#
# Bodies for use
#

body classes if_ok(class) {
        promise_kept => { "$(class)" };
        promise_repaired => { "$(class)" };
        scope => "namespace";
}

body perms set_perms(user, group, mode) {
        mode => "$(mode)";
        owners => { "$(user)" };
        groups => { "$(group)" };
        rxdirs => "true";
}

body copy_from copy(source)  {
        source => "$(source)";
}

body classes if_repaired(class) {
        promise_repaired => { "$(class)" };
        scope => "namespace";
}

#
# Install kaf_04
#

bundle agent install_kaf_04(config) {
  methods:
      "any" usebundle => install_rpm("kaf_04"),
        classes => if_repaired("kaf_04_repaired");
  files:
      "$(config[kaf_04][dirs][etc])/."
        create => "true",
        if => or(
                  "kaf_04_installed",
                  "kaf_04_install_ok"
        ),
        classes => if_repaired("kaf_04_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "750");
      "$(config[kaf_04][dirs][etc])/authorize.json"
        copy_from => copy("$(this.promise_dirname)/config/kaf_04/authorize.json"),
        if => and(
                   isdir("$(config[kaf_04][dirs][etc])/"),
                   or(
                       "kaf_04_installed",
                       "kaf_04_install_ok"
                   )
        ),
        classes => if_repaired("kaf_04_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_04][dirs][etc])/cluster.json"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_04/cluster.json.mustache",
        template_method => "mustache",
        template_data => @(config),
        if => and(
                   isdir("$(config[kaf_04][dirs][etc])/"),
                   or(
                       "kaf_04_installed",
                       "kaf_04_install_ok"
                   )
        ),
        classes => if_repaired("kaf_04_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_04][dirs][etc])/identitySuffix.json"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_04/identitySuffix.json.mustache",
        template_method => "mustache",
        template_data => @(config),
        if => and(
                   isdir("$(config[kaf_04][dirs][etc])/"),
                   or(
                       "kaf_04_installed",
                       "kaf_04_install_ok"
                   )
        ),
        classes => if_repaired("kaf_04_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
      "$(config[kaf_04][dirs][etc])/writer.json"
        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_04/writer.json.mustache",
        template_method => "mustache",
        template_data => @(config),
        if => and(
                   isdir("$(config[kaf_04][dirs][etc])/"),
                   or(
                       "kaf_04_installed",
                       "kaf_04_install_ok"
                   )
        ),
        classes => if_repaired("kaf_04_repaired"),
        perms => set_perms("srv-kaf_07", "srv-kaf_07", "640");
  reports:
      "[ERROR] kaf_04 was not properly installed"
        if => and(
                  not("kaf_04_installed"),
                  not("kaf_04_install_ok")
        );
      "[INFO] kaf_04 install changed, please restart service(s)"
        if => "kaf_04_repaired";
}

#
