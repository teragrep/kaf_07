        create => "true",
        edit_template => "$(this.promise_dirname)/templates/kaf_05/identitySuffix.json.mustache",
        template_method => "mustache",
        template_data => @(config),
        if => and(
                   isdir("$(config[kaf_05][dirs][etc])/"),
